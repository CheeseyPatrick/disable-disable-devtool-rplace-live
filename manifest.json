{
	"manifest_version": 3,
	"name": "disable-disable-devtool-rplace-live",
	"version": "1.0.0",
	"description": "Prevents the disable-devtool script from doing its job.",
	"content_scripts": [{
		"matches": ["https://rplace.live/*"],
		"js": ["content-script.js"],
		"run_at": "document_start",
		"world": "MAIN"
	}],
	"declarative_net_request": {
		"rule_resources": [{
			"id": "rule",
			"enabled": true,
			"path": "rule.json"
		}]
	},
	"permissions": ["declarativeNetRequest"]
}